# Django Settings
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Configuration
# Required for Supabase API helpers and uploaded media storage.
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=images

# Supabase PostgreSQL Database Connection
# Optional for local development; if omitted, Django falls back to SQLite.
# Get these from: Supabase Dashboard > Project Settings > Database > Connection string
# Use the "Transaction pooler" or "Session pooler" connection details
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-database-password
DB_HOST=aws-0-region.pooler.supabase.com
DB_PORT=5432
